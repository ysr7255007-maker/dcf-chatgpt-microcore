{
  "manifest_version": 3,
  "minimum_chrome_version": "138",
  "name": "DCF Chrome",
  "description": "DCF 的 Chrome 纯底座与个人独立功能插件。",
  "version": "1.0.0.3",
  "version_name": "1.0.0-rc.2.1",
  "permissions": [
    "userScripts",
    "storage",
    "tabs",
    "alarms",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://raw.githubusercontent.com/ysr7255007-maker/dcf-chatgpt-microcore/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "static/migration-bridge.js"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_title": "打开 DCF 恢复与管理"
  }
}
